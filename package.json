{
	"name": "animelens",
	"module": "src/index.ts",
	"type": "module",
	"version": "0.2.0-alpha",
	"private": true,
	"scripts": {
		"dev": "cross-env NODE_ENV=development bun run src/index.ts",
		"start": "bun run src/index.ts",
		"build": "tsc",
		"format": "prettier --write .",
		"db:generate": "cross-env NODE_ENV=development prisma generate",
		"db:migrate": "cross-env NODE_ENV=development prisma migrate dev",
