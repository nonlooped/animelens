	},
	"dependencies": {
		"@discordx/pagination": "^4.4.1",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"consola": "^3.4.2",
		"crypto": "^1.0.1",
		"discord.js": "^14.26.4",
		"ejs": "^6.0.1",
		"express": "^5.2.1",
		"pg": "^8.22.0",
		"prisma": "^7.8.0",
		"uuid": "^14.0.1"
	},
